# Azure OpenAI (Entra ID — no API key)
AZURE_OPENAI_ENDPOINT=https://YOUR-AOAI-RESOURCE.openai.azure.com
AZURE_OPENAI_MAIN_DEPLOYMENT=gpt-5.4-mini
AZURE_OPENAI_NANO_DEPLOYMENT=gpt-5-nano
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Validation middleware behaviour: advisory | rewrite | escalate
VALIDATION_MODE=rewrite

# Optional: skip the refine pass for messages this short (chars)
REFINE_SKIP_THRESHOLD=40

# Local dev only
ENVIRONMENT=local
PORT=8000
